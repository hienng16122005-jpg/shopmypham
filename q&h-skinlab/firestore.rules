rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Phase 3: Primitives & Hardened Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    // RBAC: Check role from users collection
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && getUserData().role == 'Quản trị viên';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Pillar 2: Validation Blueprints ---

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'image']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 250 &&
             data.price is number && data.price >= 0 &&
             data.image is string && data.image.size() <= 1000 &&
             (data.get('oldPrice', 0) is number) &&
             (data.get('brand', '') is string) &&
             (data.get('category', '') is string) &&
             (data.get('discount', '') is string) &&
             (data.get('sold', 0) is number) &&
             (data.get('stock', 0) is number);
    }

    function isValidCategory(data) {
      return data.keys().hasAll(['name', 'slug']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.slug is string && data.slug.size() > 0 && data.slug.size() <= 100;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'items', 'totalPrice', 'status', 'isPaid', 'createdAt']) &&
             (data.userId == null || (data.userId is string && data.userId.size() <= 128)) &&
             data.items is list && data.items.size() <= 50 &&
             data.totalPrice is number && data.totalPrice >= 0 &&
             data.status in ['Chờ xác nhận', 'Chờ lấy hàng', 'Đang giao', 'Đã giao', 'Đã huỷ'] &&
             data.isPaid is bool;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['name', 'email', 'role', 'createdAt']) &&
             data.name is string && data.name.size() <= 150 &&
             data.email is string && data.email.size() <= 150 &&
             data.role in ['Khách hàng', 'Quản trị viên'];
    }

    function isValidMagazine(data) {
      return data.keys().hasAll(['title', 'category', 'thumbnail', 'content', 'createdAt']) &&
             data.title is string && data.title.size() <= 300 &&
             data.content is string && data.content.size() <= 100000;
    }

    // --- Pillar 4 & 8: Collection Rules & Secure List Queries ---

    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct(incoming());
      allow update: if isAdmin() && isValidProduct(incoming());
      allow delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create: if isAdmin() && isValidCategory(incoming());
      allow update: if isAdmin() && isValidCategory(incoming());
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      // Secure list: Users can only see their own orders, Admin sees everything
      allow read, list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      
      // Anyone can create an order (even guest for simplicity if intended, otherwise add isSignedIn)
      allow create: if isValidOrder(incoming()) && 
                    (incoming().userId == null || incoming().userId == request.auth.uid);
      
      allow update: if (isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid)) &&
                     isValidOrder(incoming()) && (
                       isAdmin() || 
                       // User can only cancel
                       (isOwner(existing().userId) && 
                        existing().status == 'Chờ xác nhận' &&
                        incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
                        incoming().status == 'Đã huỷ')
                     );
      allow delete: if isAdmin();
    }

    match /magazine/{articleId} {
      allow read: if true;
      allow create: if isAdmin() && isValidMagazine(incoming());
      allow update: if isAdmin() && isValidMagazine(incoming());
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAdmin() || isOwner(userId);
      allow list: if isAdmin();
      
      // Pillar 6: PII Isolation - though here we allow owner to create profile
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().role == 'Khách hàng';
      
      allow update: if (isAdmin() || isOwner(userId)) &&
                     isValidUser(incoming()) && (
                       isAdmin() || (
                         isOwner(userId) && 
                         incoming().diff(existing()).affectedKeys().hasOnly(['name', 'email'])
                       )
                     );
      allow delete: if isAdmin();
    }
  }
}
