{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "E-commerce product entity",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "brand": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "oldPrice": { "type": "number" },
        "discount": { "type": "string" },
        "image": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "details": { "type": "string" },
        "specs": { "type": "object" },
        "sold": { "type": "number" },
        "stock": { "type": "number" }
      },
      "required": ["name", "price", "image"]
    },
    "Category": {
      "title": "Category",
      "description": "Product category",
      "type": "object",
      "properties": {
        "id": { "type": "integer" },
        "name": { "type": "string" },
        "slug": { "type": "string" }
      },
      "required": ["name", "slug"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "customerInfo": { "type": "object" },
        "items": { "type": "array" },
        "paymentMethod": { "type": "string" },
        "totalPrice": { "type": "number" },
        "status": { "type": "string", "enum": ["Chờ xác nhận", "Chờ lấy hàng", "Đang giao", "Đã giao", "Đã huỷ"] },
        "isPaid": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Magazine": {
      "title": "Magazine",
      "description": "Beauty magazine article",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "category": { "type": "string" },
        "thumbnail": { "type": "string" },
        "description": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "products/{productId}": {
      "schema": "Product",
      "description": "Collection of products"
    },
    "categories/{categoryId}": {
      "schema": "Category",
      "description": "Product categories"
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    },
    "magazine/{articleId}": {
      "schema": "Magazine",
      "description": "Magazine articles"
    },
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    }
  }
}
